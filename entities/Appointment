{
  "name": "Appointment",
  "type": "object",
  "properties": {
    "client_name": {
      "type": "string"
    },
    "client_phone": {
      "type": "string"
    },
    "client_email": {
      "type": "string"
    },
    "service_id": {
      "type": "string",
      "description": "ID do servi\u00e7o"
    },
    "service_name": {
      "type": "string"
    },
    "professional_id": {
      "type": "string"
    },
    "professional_name": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "time": {
      "type": "string",
